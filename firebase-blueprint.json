{
  "entities": {
    "UserProfile": {
      "title": "使用者設定檔",
      "description": "儲存使用者角色與基本資訊",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "staffId": { "type": "string", "description": "對應的員工 ID" }
      },
      "required": ["uid", "email", "role"]
    },
    "Staff": {
      "title": "員工資訊",
      "description": "工程人員基本資料",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "staffNumber": { "type": "string", "description": "工號" },
        "department": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "staffNumber"]
    },
    "Certificate": {
      "title": "證照資訊",
      "description": "員工持有的證照詳情",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "type": { "type": "string", "description": "證照類型" },
        "certNumber": { "type": "string" },
        "issueDate": { "type": "string", "format": "date" },
        "expiryDate": { "type": "string", "format": "date" },
        "documentUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["valid", "expired", "expiring_soon"] }
      },
      "required": ["staffId", "type", "certNumber", "expiryDate"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "使用者權限資料"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "員工基本資料"
    },
    "/certificates/{certId}": {
      "schema": "Certificate",
      "description": "證照詳細資料"
    }
  }
}
